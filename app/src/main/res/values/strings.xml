    <!-- Policy - About Us -->
    <string name="about_us_title">About Us</string>
    <string name="news_aggregator">News Aggregator</string>
    <string name="about_us_description">Alfa News Telugu is a News Aggregator application. We collect information from various trusted news sources, websites, and social media, and provide it to our readers concisely, \"straight, without a hammer\". Our aim is just to summarize information and make it possible to know more things in less time.</string>
    <string name="time_valuable">We understand that time is very valuable these days, which is why we provide news in 60-70 words.</string>
    <string name="our_vision">Our Vision</string>
    <string name="our_vision_description">Our vision is to stand as a reliable and important platform in the news world. We don\'t just want to report news, but analyze the facts behind them deeply and provide full awareness to our readers.</string>
    <string name="our_values">Our Values</string>
    <string name="value_honesty">• Honesty: We follow realism and transparency in every news we provide.</string>
    <string name="value_speed">• Speed: We bring it before you as soon as the event happens.</string>
    <string name="value_brevity">• Brevity: Without unnecessary details, we provide only the summary of the news.</string>
    <string name="value_public_interest">• Pro-People: We always stand on the side of the people and voice their concerns.</string>
    <string name="dmca_policy">DMCA / Takedown Policy</string>
    <string name="dmca_description">We respect others\' copyrights and intellectual property rights. If you have an objection to any content, image, or video in our app, or if you feel it violates your copyright, please let us know.</string>
    <string name="dmca_email">Email: contact@alfanews.app</string>
    <string name="dmca_response">Within 24 hours of receiving your request, we will review and remove the relevant content.</string>
    <string name="thank_you">Thank you for joining us on our journey. Your suggestions and feedback are very valuable to us.</string>

