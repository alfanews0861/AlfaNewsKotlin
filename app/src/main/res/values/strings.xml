    <!-- Policy - Content Policy -->
    <string name="content_policy_title">Content Policy</string>
    <string name="content_policy_intro">We are committed to creating a safe and respectful environment on the Alfa News Telugu platform. Everyone using our services must comply with this content policy.</string>
    <string name="copyright_complaints">Copyright Infringement Complaints:</string>
    <string name="copyright_objection">If anyone has an objection to any content or image in our app, please email us. We respect copyright laws.</string>
    <string name="prohibited_content">Prohibited Content</string>
    <string name="hate_speech_desc">• Hate Speech: Content that incites violence against individuals or groups based on race, religion, caste, gender.</string>
    <string name="harassment_desc">• Harassment and Threats: Targeting, harassing, threatening, or intimidating others.</string>
    <string name="obscenity_desc">• Obscenity and Sexual Content: Pornographic images, videos, or sexually explicit content.</string>
    <string name="violence_desc">• Violent and Graphic Content: Displaying unnecessary violence, bloodshed, or horrific images.</string>

    <!-- Policy - Data Collection Policy -->
    <string name="data_collection_title">Data Collection Policy</string>
    <string name="data_collection_intro">To provide and improve our services to you, we collect specific information.</string>
    <string name="info_types">Types of Information We Collect</string>
    <string name="info_provided">1. Information you provide to us:</string>
    <string name="account_info_desc">• Account Information: When you log in through a third-party service like Google, we receive your name, email address, and profile picture.</string>
    <string name="user_content_desc">• User Content: When you make comments or post other content on our platform, we collect that information.</string>
    <string name="info_automatic">2. Information we collect automatically:</string>
    <string name="usage_details_desc">• Usage Details: We log information about which news stories you read, what videos you watch, likes, shares, and how you interact with our app.</string>
    <string name="technical_info_desc">• Device and Technical Information: We collect information such as your IP address, device type, operating system, browser type, and unique device identifiers.</string>
    <string name="location_info_desc">• Location Information: If you give us permission, we may collect your geographical location when posting news.</string>
    <string name="why_collect_info">Why We Collect Information</string>
    <string name="why_personalize">• To provide you with personalized and relevant content.</string>
    <string name="why_analyze">• To analyze, operate, and improve our services.</string>
    <string name="why_prevent_fraud">• To prevent fraud and ensure the security of our services.</string>

    <!-- Policy - Disclaimer -->
    <string name="disclaimer_title">Disclaimer</string>
    <string name="aggregator_disclaimer">News Aggregator Disclaimer</string>
    <string name="aggregator_disclaimer_desc">Alfa News Telugu is a news collection (Aggregator) platform. The news and content published here are collected and summarized from various sources. We are not responsible for errors in the original sources.</string>
    <string name="general_info_disclaimer">The information provided on the Alfa News Telugu website/application is for general information purposes only. While we try to keep the information as accurate and up-to-date as possible, we make no guarantees about the completeness, accuracy, or reliability of the information on the website.</string>
    <string name="takedown_policy">Takedown Policy (Content Removal)</string>
    <string name="takedown_desc">If anyone has an objection to any content or image in our app, please email us. Email: contact@alfanews.app. We will respond within 24 hours and remove objectionable content.</string>
    <string name="reliance_disclaimer">Reliance on Information</string>
    <string name="reliance_desc">Any reliance you place on the information on this website is strictly at your own risk. We will not be liable for any loss or damage arising from the use of this website.</string>

    <!-- Policy - Terms of Service -->
    <string name="tos_title">Terms of Service</string>
    <string name="tos_welcome">Welcome to Alfa News Telugu (\"Service\"). By accessing or using this service, you agree to be bound by these terms of service (\"Terms\").</string>
    <string name="tos_use_service">1. Use of Service</string>
    <string name="tos_use_desc">You agree to use our service only for lawful purposes and in accordance with these terms.</string>
    <string name="tos_user_accounts">2. User Accounts</string>
    <string name="tos_accounts_desc">To access some features of our service, you may need to create an account. You are responsible for maintaining the confidentiality of your account information and for all activities that occur under your account.</string>
    <string name="tos_ip_rights">3. Intellectual Property Rights</string>
    <string name="tos_ip_desc">The service and its original content, features, and functionality are the exclusive property of Alfa News Telugu and its licensors. You may not copy, distribute, or modify this content without our written permission.</string>
    <string name="tos_user_content">4. User Content</string>
    <string name="tos_user_content_desc">If you post content (for example, comments) on our service, you are fully responsible for that content. The content you post must comply with our content policy.</string>
    <string name="tos_termination">5. Service Termination</string>
    <string name="tos_termination_desc">If you violate these terms, we may, at our sole discretion, suspend or terminate your account and your access to our service without any prior notice.</string>
    <string name="tos_changes">6. Changes to Terms</string>
    <string name="tos_changes_desc">We reserve the right to modify these terms at any time. If you continue to use our service even after any changes are made, you will be deemed to have accepted the revised terms.</string>

