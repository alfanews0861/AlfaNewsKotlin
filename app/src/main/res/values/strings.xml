    <!-- Policy - Privacy Policy -->
    <string name="privacy_policy_title">Privacy Policy</string>
    <string name="privacy_intro">Alfa News Telugu (\"we,\" \"us,\" \"our\") respects your privacy. This Privacy Policy explains what information we collect from you through our website/application (\"Service\"), how we use it, and how we protect it.</string>
    <string name="info_we_collect">Information We Collect</string>
    <string name="pii_desc">• Personal Identification Information: When you register for our service, we may collect information such as your name, email address, and profile picture.</string>
    <string name="usage_data_desc">• Usage Data: We may automatically collect information about which news you read, how much time you spend, and which features you use.</string>
    <string name="device_info_desc">• Device Information: We may collect information such as your device type, operating system, unique identifiers, and network information.</string>
    <string name="how_we_use_info">How We Use Information</string>
    <string name="use_provide_service">• To provide and maintain our service.</string>
    <string name="use_personalize">• To personalize your experience.</string>
    <string name="use_improve">• To improve our service and develop new features.</string>
    <string name="use_communicate">• To communicate with you, to send important updates or notifications.</string>
    <string name="use_fraud_prevention">• To prevent fraud and enforce our terms of service.</string>
    <string name="data_security">Data Security</string>
    <string name="data_security_desc">We take appropriate technical and organizational measures to protect your information. However, please note that data transmission over the internet is not 100%% secure.</string>

    <!-- Policy - Ad Policy -->
    <string name="ad_policy_title">Advertising Policy</string>
    <string name="ad_intro">To provide Alfa News Telugu services to our users free of charge, we display advertisements on our application and website.</string>
    <string name="ad_purpose">Purpose of Advertising</string>
    <string name="ad_pay_journalists">• To make payments to journalists and staff.</string>
    <string name="ad_cover_costs">• To cover the costs of servers, maintenance, and technical infrastructure.</string>
    <string name="ad_improve_service">• To constantly improve our services and develop new features.</string>
    <string name="ad_partners">Advertising Partners</string>
    <string name="ad_partners_desc">We work with third-party advertising networks like Google AdMob. These partners use cookies, web beacons, and other technologies to show you more relevant advertisements.</string>
    <string name="ad_types">Types of Advertisements</string>
    <string name="ad_types_desc">On our platform, you may see various types of advertisements like banner ads, interstitial (full screen) ads, and local (native) ads.</string>
    <string name="user_choices">User Choices</string>
    <string name="user_choices_desc">You have some options to control personalized advertisements. You can limit ad tracking in your mobile device\'s settings.</string>

