
rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    
    // Helper function to check if user has REPORTER role
    function hasReporterRole(uid) {
      let userDoc = firestore.get(/databases/(default)/documents/users/$(uid));
      return userDoc.exists && userDoc.data.role in ['REPORTER', 'EDITOR', 'ADMIN'];
    }

    // Helper function to check if user has ADMIN role
    function hasAdminRole(uid) {
      let userDoc = firestore.get(/databases/(default)/documents/users/$(uid));
      return userDoc.exists && userDoc.data.role == 'ADMIN';
    }

    // Allow public read access to all files
    match /{allPaths=**} {
      allow read: if true;
    }

    // User Profiles
    match /user-profiles/{allPaths=**} {
      allow write: if request.auth != null;
    }
    match /profile_photos/{allPaths=**} {
      allow write: if request.auth != null;
    }

    // Signatures
    match /signatures/{allPaths=**} {
      allow write: if request.auth != null;
    }
    
    // Generated ID Cards
    match /id-cards/{allPaths=**} {
      allow write: if request.auth != null;
    }

    // News Media: Allow users with REPORTER, EDITOR, or ADMIN roles to upload
    match /news-media/{allPaths=**} {
        allow write: if request.auth != null &&
            hasReporterRole(request.auth.uid);
    }

    // Citizen Media: Allow authenticated users to upload
    match /citizen-media/{allPaths=**} {
      allow write: if request.auth != null;
    }
    
    // Classifieds
    match /classifieds-media/{allPaths=**} {
       allow write: if request.auth != null;
    }
    
    // Local Ads
    match /local-ads/{allPaths=**} {
       allow write: if request.auth != null;
    }
    
    // General Ads Media
    match /ads-media/{allPaths=**} {
       allow write: if request.auth != null;
    }

    // Default uploads path
    match /uploads/{allPaths=**} {
       allow write: if request.auth != null;
    }
  }
}