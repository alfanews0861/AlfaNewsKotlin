rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper function to get user data
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    // User Profiles
    match /users/{userId} {
      allow read: if true;
      // Allow user to write their own profile, or admins to manage them.
      allow write: if request.auth != null && (request.auth.uid == userId ||
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        getUserData().role == 'ADMIN')
      ;
    }
    
    // News Posts
    match /news/{postId} {
      allow read: if true;
      // Allow reporters/admins/regional_incharge to create posts OR
      // any user with an existing user document (i.e., a role) to create a citizen post.
      allow create: if request.auth != null && (
                      (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && (
                       getUserData().role in ['REPORTER', 'EDITOR', 'ADMIN', 'NEWS_DESK'] ||
                       (getUserData().role == 'REGIONAL_INCHARGE' && request.resource.data.district in getUserData().assignedDistricts)
                      )) ||
                      (request.resource.data.isCitizen == true)
                    );
      allow update, delete: if request.auth != null && exists(/databases/$(database)/documents/users/$(request.auth.uid)) && (
        getUserData().role in ['EDITOR', 'ADMIN', 'NEWS_DESK'] ||
        (getUserData().role == 'REPORTER' && resource.data.reporter.id == request.auth.uid) ||
        (getUserData().role == 'REGIONAL_INCHARGE' && resource.data.district in getUserData().assignedDistricts)
      );

      // Survey Vote Update: any signed-in user may increment vote counts on a survey post.
      // Only the 'votes.*' and 'realVotesCount' fields may be written (read-only check is enforced client-side).
      allow update: if request.auth != null
                    && resource.data.type == "survey"
                    && request.resource.data.diff(resource.data).affectedKeys()
                        .hasOnly(['votes', 'realVotesCount']);

      // Comments Sub-collection
      match /comments/{commentId} {
        allow read: if true;
        allow create: if request.auth != null;
        allow delete: if request.auth != null && (resource.data.userId == request.auth.uid ||
                       (exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
                        getUserData().role == 'ADMIN'));
      }

      // Survey Voted-Users Sub-collection
      // Each user can only create their own receipt document (write-once, prevents double voting).
      match /voted_users/{userId} {
        allow read: if request.auth != null && request.auth.uid == userId;
        allow create: if request.auth != null
                      && request.auth.uid == userId
                      && !exists(/databases/$(database)/documents/news/$(postId)/voted_users/$(userId));
        allow update, delete: if false; // Immutable once cast
      }
    }
    
    // RSS, Social & Scraping Feeds (Admin only write)
    match /rss_feeds/{feedId} {
      allow read: if true;
      allow write: if request.auth != null && exists(/databases/$(database)/documents/users/$(request.auth.uid)) && getUserData().role == 'ADMIN';
    }
    match /social_feeds/{feedId} {
      allow read: if true;
      allow write: if request.auth != null && exists(/databases/$(database)/documents/users/$(request.auth.uid)) && getUserData().role == 'ADMIN';
    }
    match /scraping_sources/{sourceId} {
      allow read: if true;
      allow write: if request.auth != null && exists(/databases/$(database)/documents/users/$(request.auth.uid)) && getUserData().role == 'ADMIN';
    }

    // System Settings - Public Read, Admin Write
    match /settings/{settingId} {
      allow read: if true;
      allow write: if request.auth != null && exists(/databases/$(database)/documents/users/$(request.auth.uid)) && getUserData().role == 'ADMIN';
    }

    // System Settings (Old name, kept for compatibility) - Public Read, Admin Write
    match /system_settings/{settingId} {
      allow read: if true;
      allow write: if request.auth != null && exists(/databases/$(database)/documents/users/$(request.auth.uid)) && getUserData().role == 'ADMIN';
    }
    
    // Contact Messages (Public write, Admin read)
    match /contact_messages/{messageId} {
      allow create: if true;
      allow read, delete, update: if request.auth != null && exists(/databases/$(database)/documents/users/$(request.auth.uid)) && getUserData().role == 'ADMIN';
    }
    
    // Classifieds
    match /classifieds/{adId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null && (resource.data.userId == request.auth.uid ||
                             (exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
                              getUserData().role == 'ADMIN'));
    }
    
    // Analytics
    match /user_analytics/{eventId} {
      allow create: if true;
      allow read: if request.auth != null && exists(/databases/$(database)/documents/users/$(request.auth.uid)) && getUserData().role == 'ADMIN';
    }

    // Ads Manager
    match /local_ads/{adId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update: if request.auth != null && (resource.data.userId == request.auth.uid ||
                    (exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
                     getUserData().role == 'ADMIN'));
    }

    // Reporters WhatsApp
    match /reporters_whatsapp/{userId} {
      allow read, write: if request.auth != null && (request.auth.uid == userId ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
         getUserData().role == 'ADMIN')
      );
    }

    // WhatsApp Queue
    match /whatsapp_queue/{queueId} {
      allow read: if request.auth != null && exists(/databases/$(database)/documents/users/$(request.auth.uid)) && getUserData().role == 'ADMIN';
      allow write: if false; // Only manageable via Cloud Functions and Admin SDK Server
    }

    // Monthly Leaderboard - Public Read, Admin Write
    match /monthly_leaderboard/{monthId} {
      allow read: if true;
      allow write: if request.auth != null && exists(/databases/$(database)/documents/users/$(request.auth.uid)) && getUserData().role == 'ADMIN';

      match /reporters/{reporterId} {
        allow read: if true;
        allow write: if request.auth != null && exists(/databases/$(database)/documents/users/$(request.auth.uid)) && getUserData().role == 'ADMIN';
      }
    }

    // Reporter Applications
    match /reporter_applications/{appId} {
      allow create: if true;
      allow read, update, delete: if request.auth != null && exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
                                  getUserData().role in ['ADMIN', 'REGIONAL_INCHARGE'];
    }

    // Anonymous/Guest Devices for Notifications
    match /anonymous_devices/{deviceId} {
      allow read: if request.auth != null && exists(/databases/$(database)/documents/users/$(request.auth.uid)) && getUserData().role == 'ADMIN';
      allow create, update: if true;
    }
  }
}